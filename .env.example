# LLM은 OpenAI 기본, 키가 없으면 자동으로 로컬 Ollama로 전환됩니다.
# OpenAI를 쓰려면 아래 키를 채운 뒤 이 파일을 .env 로 복사하세요.
# (Ollama만 쓸 거면 키는 비워도 됩니다.)
OPENAI_API_KEY=sk-여기에_본인_키를_넣으세요

# 선택: 모델/파라미터 (없으면 기본값 사용)
# OPENAI_MODEL=gpt-4o-mini
# TEMPERATURE=0.8
# CONV_TURNS=4
# NUM_DAYS=2

# 선택: LLM 공급자 강제 지정 (auto | openai | ollama). 기본 auto
# LLM_PROVIDER=auto
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
